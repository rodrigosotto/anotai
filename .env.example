# ─── Ambiente ──────────────────────────────────────────────────────────────────
# Valores: development | preview | production
APP_ENV=development

# ─── EAS / Expo ────────────────────────────────────────────────────────────────
# ID do projeto no EAS (obtido com `eas init`)
EAS_PROJECT_ID=YOUR_EAS_PROJECT_ID

# ─── Futuro: autenticação (ex: Supabase) ──────────────────────────────────────
# SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# SUPABASE_ANON_KEY=YOUR_ANON_KEY

# ─── Futuro: monitoramento de erros (ex: Sentry) ──────────────────────────────
# SENTRY_DSN=https://YOUR_DSN@sentry.io/PROJECT_ID

# Nota: Nunca commite o arquivo .env real (já está no .gitignore)
